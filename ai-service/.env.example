# ============================================================
# AI Service Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# LLM Provider (groq | gemini | anthropic | openai | deepseek | ollama)
LLM_PROVIDER=groq

# Override default model for the selected provider (optional)
# Defaults per provider:
#   groq      -> llama-3.1-8b-instant
#   gemini    -> gemini-2.0-flash
#   anthropic -> claude-sonnet-4-6
#   openai    -> gpt-4o-mini
#   deepseek  -> deepseek-chat
#   ollama    -> llama3.1
# LLM_MODEL=

# Request timeout in seconds (optional)
# LLM_TIMEOUT_SECONDS=60

# ----------------------------------------------------------
# Provider: Groq (free tier, fast, recommended for demo)
# Get key: https://console.groq.com/keys
# ----------------------------------------------------------
# GROQ_API_KEY=your_groq_api_key

# ----------------------------------------------------------
# Provider: Google Gemini (free tier available)
# Get key: https://aistudio.google.com/app/apikey
# ----------------------------------------------------------
# GOOGLE_API_KEY=your_google_api_key

# ----------------------------------------------------------
# Provider: Anthropic Claude
# Get key: https://console.anthropic.com/
# ----------------------------------------------------------
# ANTHROPIC_API_KEY=your_anthropic_api_key

# ----------------------------------------------------------
# Provider: OpenAI
# Get key: https://platform.openai.com/api-keys
# ----------------------------------------------------------
# OPENAI_API_KEY=your_openai_api_key

# ----------------------------------------------------------
# Provider: DeepSeek (OpenAI-compatible API)
# Get key: https://platform.deepseek.com/api_keys
# ----------------------------------------------------------
# DEEPSEEK_API_KEY=your_deepseek_api_key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ----------------------------------------------------------
# Provider: Ollama (local, no API key needed)
# ----------------------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434

# ----------------------------------------------------------
# Database (for RAG chatbot)
# ----------------------------------------------------------
DATABASE_URL=postgresql://invoice_user:invoice_pass@localhost:5432/invoice_demo
